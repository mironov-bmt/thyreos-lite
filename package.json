    "type": "git",
    "url": "https://github.com/mironov-bmt/thyreos-lite.git"
  },
  "keywords": [
    "encryption",
    "cryptography",
    "browser",
    "web-crypto-api",
    "rsa",
    "ecdsa",
    "aes-gcm",
    "educational",
    "client-side",
    "security"
  ],
  "author": "Thyreos Lite Contributors",
