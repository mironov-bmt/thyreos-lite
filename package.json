{
  "name": "thyreos-lite",
  "version": "1.0.0",
  "description": "Educational browser-based file encryption tool using RSA-4096, ECDSA P-256, and AES-256-GCM",
  "main": "index.html",
  "scripts": {
    "start": "echo 'Open index.html directly in your browser. No server required.'",
    "serve": "python3 -m http.server 8080 || python -m SimpleHTTPServer 8080"
  },
